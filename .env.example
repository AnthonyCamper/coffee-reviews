# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
# The VAPID public key is NOT a secret. Generate a key pair with:
#   node scripts/generate-vapid-keys.js
# Put the public key here AND set the private key as a Supabase Edge Function secret.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ─── Tenor GIF API ────────────────────────────────────────────────────────────
# Get a free API key at https://developers.google.com/tenor/guides/quickstart
VITE_TENOR_API_KEY=your-tenor-api-key-here

# ─── Site Title ───────────────────────────────────────────────────────────────
# Replace Talia's with the actual name everywhere in the codebase.
# Search for Talia's and replace all occurrences.
# VITE_SITE_NAME=Talia's   ← optional if you prefer env-driven title
